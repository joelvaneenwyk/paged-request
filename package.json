{
  "name": "paged-request",
  "description": "Simplified requests for paged (paginated) content.",
  "version": "2.0.2",
  "homepage": "https://github.com/jonschlinkert/paged-request",
  "author": "Jon Schlinkert (https://github.com/jonschlinkert)",
  "repository": "jonschlinkert/paged-request",
  "bugs": {
    "url": "https://github.com/jonschlinkert/paged-request/issues"
  },
  "license": "MIT",
  "files": [
    "index.js"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=8"
  },
  "scripts": {
    "test": "mocha",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/axios": "^0.14.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "globals": "^15.15.0",
    "gulp-format-md": "github:joelvaneenwyk/gulp-format-md",
    "mocha": "^11.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  },
  "keywords": [
    "get",
    "paged",
    "paginated",
    "request"
  ],
  "verb": {
    "toc": false,
    "layout": "default",
    "tasks": [
      "readme"
    ],
    "plugins": [
      "gulp-format-md"
    ],
    "related": {
      "list": [
        "gists",
        "github-base",
        "repos"
      ]
    },
    "lint": {
      "reflinks": true
    },
    "reflinks": [
      "axios",
      "needle"
    ]
  }
}
